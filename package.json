{
  "name": "ehdb-permit-validator",
  "version": "0.1.0",
  "description": "Multi-platform EHDB digital permit validator for HDAB — SPE Operators, Data Holders, and Data Users",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "build:mac": "vite build && electron-builder --mac",
    "build:linux": "vite build && electron-builder --linux",
    "preview": "vite preview"
  },
  "build": {
    "appId": "eu.hdab.permit-validator",
    "productName": "HDAB-NL Permit Validator",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": ["nsis", "msi"]
    },
    "mac": {
      "target": ["dmg", "pkg"]
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm"]
    }
  },
  "keywords": ["EHDS", "EHDB", "HDAB", "permit", "validator"],
  "author": "HDAB NL",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.0.2",
    "lucide-react": "^0.468.0"
  }
}
