{
  "name": "ehdb-permit-validator",
  "version": "0.1.0",
  "description": "Multi-platform EHDB digital permit validator for HDAB — SPE Operators, Data Holders, and Data Users",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "build:mac": "vite build && electron-builder --mac",
    "build:linux": "vite build && electron-builder --linux",
    "preview": "vite preview"
  },
  "build": {
    "appId": "eu.hdab.permit-validator",
    "productName": "HDAB-NL Permit Validator",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "msi"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "pkg"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ]
    }
  },
  "keywords": [
    "EHDS",
    "EHDB",
    "HDAB",
    "permit",
    "validator"
  ],
  "author": "HDAB NL",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.7.2",
    "lucide-react": "^0.468.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.0.2"
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "esbuild@0.25.12": true,
    "fsevents@2.3.3": true
  }
}
